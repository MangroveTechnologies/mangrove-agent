# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl

# Virtual environments
venv/
.venv/
env/

# Environment and secrets
.env
*.env.local
local-config.json

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Terraform
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/.terraform.lock.hcl

# Logs
logs/
*.log

# Docker
docker-compose.override.yml

# Per-user onboarding state (written by /onboard skill on completion;
# presence suppresses the SessionStart onboarding reminder). This is
# intentionally NOT committed -- each clone re-onboards on first run.
.claude/.onboarded

# Claude Code MCP registration. Written by scripts/setup-mcp.sh into the
# user's ~/.claude.json (user scope) and also as a convenience copy at
# the repo root. Per-user state — never committed.
.mcp.json

# Internal docs (not for public repo)
TEMPLATE-REVIEW.md
ROADMAP.md
docs/plans/
agent.db

# All durable agent state lives here (SQLite DB, Fernet master key, any
# future per-install state). Bind-mounted as a directory into Docker
# containers so single-file bind-mount staleness can't eat state.
# Per-machine, never committed.
agent-data/

# Pytest scratch — same shape as agent-data/ but created by tests that
# set MASTER_KEY_PATH to a test-scoped path. CWD at test time is
# server/, so the dir lands at server/agent-data-test/.
**/agent-data-test/

server/scripts/first_live_swap.py

# Slide-source pptx — bulky binary; the rendered .pdf is the committed artifact.
# If you need to commit a specific pptx, use git add -f.
*.pptx

# Stale workshop binaries — canonical copies live under docs/workshop/.
# These were collocated by PR #64 and should not reappear at the repo root.
/bots-and-bytes-v5.*
/workshop-run-of-show.*
/workshop-setup-guide.*
.Rhistory
