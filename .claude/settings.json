{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-wallet-secrets.sh --mode user",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-wallet-secrets.sh --mode tool",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-main-commits.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "mcp__defi-agent__execute_swap",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/preflight-swap.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
